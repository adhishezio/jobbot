# --- Database ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me
POSTGRES_DB=jobbot_db

# --- n8n Security & Networking ---
N8N_ENCRYPTION_KEY=change_me
# Example: 192.168.1.50
LAN_IP=192.168.1.50

# --- External APIs ---
GEMINI_API_KEY=your_gemini_api_key
SERPAPI_KEY=your_serpapi_key

# --- Vertex AI (for n8n cover-letter generation) ---
# Paste the full Service Account JSON on one single line.
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"your-project-id"}
VERTEX_AI_PROJECT_ID=your-project-id
VERTEX_AI_LOCATION=global
VERTEX_EXTRACTION_MODEL=gemini-2.5-flash
VERTEX_GENERATOR_MODEL=gemini-2.5-pro
VERTEX_CRITIC_MODEL=gemini-2.5-flash
VERTEX_REFINER_MODEL=gemini-2.5-pro
NODE_FUNCTION_ALLOW_EXTERNAL=google-auth-library

# --- Optional ---
# TELEGRAM_BOT_TOKEN=
